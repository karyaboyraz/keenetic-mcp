# Copy this file to `.env` and fill in your router's details.
# `.env` is gitignored — never commit your real password.

# Your router's base URL (the address you use for the web admin panel).
KEENETIC_URL=http://192.168.1.1

# Admin credentials.
KEENETIC_USER=admin
KEENETIC_PASS=your-router-admin-password

# Write tools (set_static_lease, pin_device, rename_device, remove_static_lease,
# reboot) are DISABLED by default so nothing can change your router by accident.
# Set this to 1 to enable them. Read tools always work regardless.
KEENETIC_ENABLE_WRITES=0

# MCP transport: stdio (default) | http | sse.
# - stdio: the client launches the server and talks over stdin/stdout (Claude
#   Desktop and most desktop clients). No host/port needed.
# - http/sse: run as a long-lived network service (e.g. via systemd) and point
#   clients at the URL below.
KEENETIC_TRANSPORT=stdio

# Where the HTTP/SSE transport listens (only used when KEENETIC_TRANSPORT=http|sse).
# Use 127.0.0.1 if you only connect from the same machine.
KEENETIC_HOST=0.0.0.0
KEENETIC_PORT=8905
